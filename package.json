{
  "name": "pedro-lucena-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run check",
    "react-doctor": "bunx -y react-doctor@latest .",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-typed": "^2.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "25.2.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}